APP_NAME="The Food Store API"
APP_VERSION="1.0.0"
ENVIRONMENT="development"  # development | production

# Base de datos — opción 1: URL directa (recomendado para Docker)
DATABASE_URL="sqlite:///./the_food_store.db"

# Base de datos — opción 2: variables individuales (si no usás DATABASE_URL)
# DB_USER="postgres"
# DB_PASSWORD="tu_contraseña_aqui"
# DB_NAME="foodstore_db"
# DB_HOST="localhost"
# DB_PORT=5432

# Frontend — origen permitido para CORS
FRONTEND_ORIGIN="http://localhost:5173"

# JWT — NUNCA usar un valor débil en producción
# Generá una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY="G5FG6WER8G4R2S2N8T2FG6RYHYJ9UY6F"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Seed — Credenciales del administrador inicial
# Usadas por: python -m app.db.seed
ADMIN_EMAIL="admin@tudominio.com"
ADMIN_PASSWORD="CambiaEstoEnProduccion1!"

# MercadoPago — Integración para pagos en línea
MP_ACCESS_TOKEN="tu_mp_access_token_aqui"
MP_WEBHOOK_SECRET="tu_mp_webhook_secret_aqui"

